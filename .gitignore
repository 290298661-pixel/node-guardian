# ===================================================================
# Node-Guardian - Official .gitignore
# ==================================================================

# -----------------------------------------------------------------
# 1. 核心安全隔离
# 阻断所有私钥、证书、K8s 集群访问凭证及本地环境变量
*.pem
*.key
*.pub
*.crt
*.p15
*.pfx
kubeconfig
*kubeconfig*
.kube/
.env
.env.*
!.env.template
secrets/
*.token
*cred*

# ------------------------------------------------------------------
# 2. 排障日志与系统备份
# -----------------------------------------------------------------
*.log
logs/
/var/log/cn-guardian.*
*.bak
*.tmp
*.temp
*.out
*.pid
*.swp
*.swo
*~

# ------------------------------------------------------------------
# 3. 自动化测试与CI遗留
# ------------------------------------------------------------------
.bats-*.tmp
test-results/
junit-*.xml
.kind-cluster/
.pytest_cache/
__pycache__/

# -------------------------------------------------------------------
# 4. 常见编辑器与操作系统垃圾文件
# ------------------------------------------------------------------
# 个人开发环境配置，不进入公共团队仓库
.vscode/
!.vscode/extensions.json
.idea/
*.tmux
.DS_Store
.DS_Store?
._*
Thumbs.db
desktop.ini
